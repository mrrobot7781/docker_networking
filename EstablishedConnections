import hashlib

password = input("Create Password: ")

upper = False
lower = False
digit = False
special = False

for ch in password:

    if ch.isupper():
        upper = True

    elif ch.islower():
        lower = True

    elif ch.isdigit():
        digit = True

    else:
        special = True

if len(password) >= 8 and upper and lower and digit and special:
    print("Strong Password")
else:
    print("Weak Password")

stored = hashlib.sha256(password.encode()).hexdigest()

login = input("Enter Password: ")

check = hashlib.sha256(login.encode()).hexdigest()

if stored == check:
    print("Login Successful")
else:
    print("Wrong Password")
